<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.todolist.controller.RegisterController"
      prefWidth="400.0" stylesheets="@../css/login.css">

    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/></padding>

    <Text text="Registro de Usuario" styleClass="title-text"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Ap. Paterno:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtApPaterno" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Ap. Materno:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="txtApMaterno" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="F. Nacimiento:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <DatePicker fx:id="dpFechaNac" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="200"/>

        <Label text="RFC:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtRfc" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Contraseña:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <Button text="Registrarme" onAction="#onRegister" prefWidth="Infinity" styleClass="login-button"/>
    <Hyperlink text="Volver al Login" onAction="#onBackToLogin"/>
</VBox>