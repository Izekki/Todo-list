<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane alignment="CENTER" xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.todolist.controller.ChangePasswordController"
           prefHeight="600.0" prefWidth="800.0"
           style="-fx-background-color: -dark-bg;">

    <VBox spacing="30.0" maxWidth="450" styleClass="card" alignment="CENTER">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
        </padding>

        <Text text="PROTOCOL_SECURITY" styleClass="title-text" style="-fx-font-size: 24;"/>

        <VBox spacing="15.0" fillWidth="true">
            <VBox spacing="8.0">
                <Label text="CONTRASEÑA ACTUAL" style="-fx-font-weight: bold; -fx-text-fill: -neon-blue; -fx-font-size: 11;"/>
                <PasswordField fx:id="txtCurrentPassword" promptText="••••••••"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="NUEVA CLAVE" style="-fx-font-weight: bold; -fx-text-fill: -neon-blue; -fx-font-size: 11;"/>
                <PasswordField fx:id="txtNewPassword" promptText="NUEVA_CLAVE"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="CONFIRMAR CLAVE" style="-fx-font-weight: bold; -fx-text-fill: -neon-blue; -fx-font-size: 11;"/>
                <PasswordField fx:id="txtConfirmPassword" promptText="REPETIR_CLAVE"/>
            </VBox>
        </VBox>

        <VBox spacing="15.0" alignment="CENTER">
            <Button text="ACTUALIZAR PROTOCOLO" onAction="#onSave" prefWidth="Infinity" styleClass="button-primary"/>
            <Button text="ABORTAR" onAction="#onCancel" prefWidth="Infinity" styleClass="button-danger"/>
        </VBox>
    </VBox>

</StackPane>
