<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.todolist.controller.LoginController"
      prefHeight="400.0" prefWidth="350.0"
      stylesheets="@../css/login.css">

    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
    </padding>

    <Text text="Iniciar Sesión" styleClass="title-text"/>

    <VBox spacing="5.0">
        <Label text="RFC:"/>
        <TextField fx:id="txtRfc" promptText="Ingrese su RFC"/>
    </VBox>

    <VBox spacing="5.0">
        <Label text="Contraseña:"/>
        <PasswordField fx:id="txtPassword" promptText="********"/>
    </VBox>

    <VBox spacing="10.0" alignment="CENTER">
        <Button text="Entrar" onAction="#onLogin" prefWidth="Infinity" styleClass="login-button"/>
        <Hyperlink text="¿No tienes cuenta? Regístrate aquí" onAction="#onGoToRegister"/>
    </VBox>

</VBox>